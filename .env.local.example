# Ramp developer API key
# Get from: ramp.com → Settings → Developer → API Keys
RAMP_API_KEY=

# Google Service Account JSON (paste the entire JSON as one line)
# 1. Go to console.cloud.google.com → your project
# 2. Enable "Google Sheets API"
# 3. IAM & Admin → Service Accounts → Create → download JSON key
# 4. Share the Podscale sheet with the service account email (Viewer)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Podscale spreadsheet ID (do not change unless the sheet moves)
PODSCALE_SPREADSHEET_ID=1InhmO83-a7Z3U2GSGABE2AAnkoU77_fnI897J9d7sl4

# Slack incoming webhook URL for #podcast-invoices
# Apps → Incoming Webhooks → Add → select #podcast-invoices → copy URL
SLACK_WEBHOOK_URL=

# Optional: set a secret to protect the /api/reconcile endpoint
# If set, requests must include: Authorization: Bearer <this value>
# Vercel cron calls will include this automatically when configured in Vercel dashboard
CRON_SECRET=
